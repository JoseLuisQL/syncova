# Frontend
VITE_API_URL=/api
VITE_APP_NAME=SIVAC
VITE_APP_VERSION=1.0.0
VITE_LOG_LEVEL=info

# Docker / despliegue
APP_DOMAIN=sivac.qware.me
FRONTEND_PORT=5173
BACKEND_PORT=3001
FRONTEND_BIND_IP=127.0.0.1
BACKEND_BIND_IP=127.0.0.1
POSTGRES_DB=sivac
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password
POSTGRES_IMAGE=postgres:17-alpine
JWT_SECRET=change_this_jwt_secret_with_at_least_32_characters
JWT_EXPIRES_IN=24h
CORS_ORIGIN=https://sivac.qware.me,http://sivac.qware.me,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info
API_VERSION=v1
DB_RESTORE_FILE=/docker/sql/init.sql
DB_RESTORE_REQUIRED=true

# SiBot / IA (opcionales)
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
GOOGLE_GENERATIVE_AI_API_KEY=
SIBOT_GOOGLE_API_KEY=
