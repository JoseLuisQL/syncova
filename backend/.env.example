# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:luis789JLQL@localhost:5432/sivac?schema=public"

# Puerto del servidor
PORT=3001

# JWT Secret (cambiar en producción)
JWT_SECRET="tu_jwt_secret_muy_seguro_aqui_cambiar_en_produccion"
JWT_EXPIRES_IN="24h"

# Configuración de CORS
CORS_ORIGIN="http://localhost:5173"

# Configuración de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configuración de logs
LOG_LEVEL="info"

# Configuración de la aplicación
NODE_ENV="development"
API_VERSION="v1"

# Configuración de archivos
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"

# Configuración de alertas
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM="noreply@saludapurimac.gob.pe"
ALERT_EMAIL_TO="admin@saludapurimac.gob.pe"

# Configuración de backup
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
