// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ENUMS
// =====================================================

enum TipoEstablecimiento {
  centro_salud
  puesto_salud
  hospital
}

enum EstadoGeneral {
  activo
  inactivo
}

enum EstadoPlanificacion {
  borrador
  aprobado
  ejecutado
}

enum EstadoLote {
  disponible
  vencido
  agotado
}

enum FormaIngreso {
  PRIMER_TRIMESTRE @map("1° TRIMESTRE")
  SEGUNDO_TRIMESTRE @map("2° TRIMESTRE")
  TERCER_TRIMESTRE @map("3° TRIMESTRE")
  CUARTO_TRIMESTRE @map("4° TRIMESTRE")
}

enum ComprobanteClase {
  PECOSA
  GUIA
  TRASLADO
  OTROS
}

enum RolUsuario {
  administrador
  coordinador
  responsable_acopio
  operador
}

enum TipoMovimientoKardex {
  ingreso
  salida
  transferencia
  ajuste
}

enum EstadoVale {
  generado
  impreso
  entregado
}

enum TipoVale {
  completo
  solo_base
  solo_adicionales
}

enum TipoAlerta {
  vencimiento
  stock_bajo
  discrepancia
  sistema
}

enum NivelAlerta {
  info
  warning
  error
  success
}

// =====================================================
// MODELOS
// =====================================================

model Red {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre      String        @unique @db.VarChar(255)
  codigo      String?       @unique @db.VarChar(50)
  descripcion String?       @db.Text
  estado      EstadoGeneral @default(activo)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  microredes  Microred[]

  @@map("redes")
}

model Microred {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre        String        @db.VarChar(255)
  codigo        String?       @db.VarChar(50)
  descripcion   String?       @db.Text
  redId         String        @map("red_id") @db.Uuid
  estado        EstadoGeneral @default(activo)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  red           Red           @relation(fields: [redId], references: [id])
  centrosAcopio CentroAcopio[]

  @@unique([nombre, redId], name: "uk_microred_nombre_red")
  @@map("microredes")
}

model CentroAcopio {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre      String        @db.VarChar(255)
  codigo      String?       @unique @db.VarChar(50)
  microredId  String?       @map("microred_id") @db.Uuid
  direccion   String        @db.Text
  responsable String        @db.VarChar(255)
  telefono    String?       @db.VarChar(20)
  estado      EstadoGeneral @default(activo)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  microred        Microred?         @relation(fields: [microredId], references: [id])
  establecimientos Establecimiento[]
  usuarios        Usuario[]         @relation("UsuarioCentroAcopioPrincipal")
  usuariosAsignados UsuarioCentroAcopio[]
  valesEntrega    ValeEntrega[]
  configuracionesJeringaVacuna ConfiguracionJeringaVacunaCentro[]

  @@unique([nombre, microredId], name: "uk_centro_acopio_nombre_microred")
  @@map("centros_acopio")
}

model Establecimiento {
  id                String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre            String                @db.VarChar(255)
  tipo              TipoEstablecimiento
  codigo            String                @unique @db.VarChar(50)
  centroAcopioId    String                @map("centro_acopio_id") @db.Uuid
  direccion         String                @db.Text
  responsable       String                @db.VarChar(255)
  telefono          String?               @db.VarChar(20)
  estado            EstadoGeneral         @default(activo)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  centroAcopio      CentroAcopio          @relation(fields: [centroAcopioId], references: [id])
  usuarios          Usuario[]
  planificaciones   PlanificacionAnual[]
  movimientos       MovimientoVacuna[]
  valesDetalle      ValeDetalle[]
  kardexOrigen      Kardex[]              @relation("KardexOrigen")
  kardexDestino     Kardex[]              @relation("KardexDestino")
  iciDemidRegistros IciDemidRegistro[]

  @@map("establecimientos")
}

model Vacuna {
  id                        String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre                    String                @db.VarChar(255)
  tipo                      String                @db.VarChar(100)
  presentacion              String                @db.VarChar(100)
  dosisPorFrasco            Int                   @map("dosis_por_frasco")
  tiempoVidaUtil            Int                   @map("tiempo_vida_util")
  temperaturaAlmacenamiento String                @map("temperatura_almacenamiento") @db.VarChar(50)
  estado                    EstadoGeneral         @default(activo)
  createdAt                 DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  lotes                     LoteVacuna[]
  planificaciones           PlanificacionAnual[]
  movimientos               MovimientoVacuna[]
  valesDetalle              ValeDetalle[]
  configuracionesDefecto    ConfiguracionJeringaVacunaDefecto[]
  configuracionesCentro     ConfiguracionJeringaVacunaCentro[]
  programacionesCenares     ProgramacionAnualCenares[] @relation("ProgramacionCenaresVacuna")
  stocksInicialesMensuales  StockInicialMensual[]
  iciDemidRegistros         IciDemidRegistro[]

  @@map("vacunas")
}

model Jeringa {
  id        String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tipo      String        @db.VarChar(100)
  capacidad String        @db.VarChar(20)
  color     String        @db.VarChar(50)
  estado    EstadoGeneral @default(activo)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  lotes                     LoteJeringa[]
  configuracionesDefecto    ConfiguracionJeringaVacunaDefecto[]
  configuracionesCentro     ConfiguracionJeringaVacunaCentro[]
  programacionesCenares     ProgramacionAnualCenares[] @relation("ProgramacionCenaresJeringa")

  @@map("jeringas")
}

model LoteVacuna {
  id                  String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  numero              String           @unique @db.VarChar(100)
  vacunaId            String           @map("vacuna_id") @db.Uuid
  fechaIngreso        DateTime         @map("fecha_ingreso") @db.Date
  fechaVencimiento    DateTime         @map("fecha_vencimiento") @db.Date
  formaIngreso        FormaIngreso     @map("forma_ingreso")
  comprobanteClase    ComprobanteClase @map("comprobante_clase")
  numeroComprobante   String           @map("numero_comprobante") @db.VarChar(100)
  cantidadInicial     Int              @map("cantidad_inicial")
  cantidadActual      Int              @map("cantidad_actual")
  estado              EstadoLote       @default(disponible)
  observaciones       String?          @db.Text
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  vacuna              Vacuna           @relation(fields: [vacunaId], references: [id])

  @@map("lotes_vacunas")
}

model LoteJeringa {
  id                  String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  jeringaId           String           @map("jeringa_id") @db.Uuid
  numero              String           @unique @db.VarChar(100)
  fechaIngreso        DateTime         @map("fecha_ingreso") @db.Date
  fechaVencimiento    DateTime?        @map("fecha_vencimiento") @db.Date
  formaIngreso        FormaIngreso     @map("forma_ingreso")
  comprobanteClase    ComprobanteClase @map("comprobante_clase")
  numeroComprobante   String           @map("numero_comprobante") @db.VarChar(100)
  cantidadInicial     Int              @map("cantidad_inicial")
  cantidadActual      Int              @map("cantidad_actual")
  estado              EstadoLote       @default(disponible)
  observaciones       String?          @db.Text
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  jeringa             Jeringa          @relation(fields: [jeringaId], references: [id])

  @@map("lotes_jeringas")
}

model Usuario {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombres           String           @db.VarChar(255)
  apellidos         String           @db.VarChar(255)
  email             String           @unique @db.VarChar(255)
  usuario           String           @unique @db.VarChar(100)
  passwordHash      String           @map("password_hash") @db.VarChar(255)
  rol               RolUsuario       // Mantener para compatibilidad
  roleId            String?          @map("role_id") @db.Uuid // Nueva relación con tabla roles
  establecimientoId String?          @map("establecimiento_id") @db.Uuid // Mantener para compatibilidad
  centroAcopioId    String?          @map("centro_acopio_id") @db.Uuid
  estado            EstadoGeneral    @default(activo)
  ultimoAcceso      DateTime?        @map("ultimo_acceso") @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  establecimiento   Establecimiento? @relation(fields: [establecimientoId], references: [id])
  centroAcopio      CentroAcopio?    @relation("UsuarioCentroAcopioPrincipal", fields: [centroAcopioId], references: [id])
  centrosAcopioAsignados UsuarioCentroAcopio[]
  role              Role?            @relation("UsuarioRole", fields: [roleId], references: [id])
  movimientos       MovimientoVacuna[]
  entregas          EntregaAdicional[]
  vales             ValeEntrega[]
  kardex            Kardex[]
  alertas           Alerta[]
  iciDemidRegistros IciDemidRegistro[]
  permisosOperativos       PermisoOperativo[] @relation("PermisoOperativoUsuario")
  permisosOperativosCreados PermisoOperativo[] @relation("PermisoOperativoCreadoPor")

  @@index([roleId], name: "idx_usuario_role")
  @@index([centroAcopioId], name: "idx_usuario_centro_acopio")
  @@map("usuarios")
}

model UsuarioCentroAcopio {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId       String       @map("usuario_id") @db.Uuid
  centroAcopioId  String       @map("centro_acopio_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  usuario         Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  centroAcopio    CentroAcopio @relation(fields: [centroAcopioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, centroAcopioId], name: "uk_usuario_centro_acopio")
  @@index([usuarioId], name: "idx_usuario_centro_usuario")
  @@index([centroAcopioId], name: "idx_usuario_centro_centro")
  @@map("usuarios_centros_acopio")
}

model IciDemidRegistro {
  id                   String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  establecimientoId    String          @map("establecimiento_id") @db.Uuid
  vacunaId             String          @map("vacuna_id") @db.Uuid
  anio                 Int
  microRed             String          @map("micro_red") @db.VarChar(255)
  codigoMed            String          @map("codigo_med") @db.VarChar(50)
  medicamentoOriginal  String          @map("medicamento_original") @db.VarChar(255)
  medff                String?         @db.VarChar(50)
  medtip               String?         @db.VarChar(50)
  medpet               String?         @db.VarChar(50)
  medest               String?         @db.VarChar(50)
  distribucionMensual  Int[]           @default([]) @map("distribucion_mensual")
  mesesDisponibles     Int[]           @default([]) @map("meses_disponibles")
  stockFin             Int             @default(0) @map("stock_fin")
  totalDistribu        Int             @default(0) @map("total_distribu")
  mesRotacion          Int?            @map("mes_rotacion")
  cpma                 Decimal?        @db.Decimal(12, 4)
  mesAbastec           Decimal?        @map("mes_abastec") @db.Decimal(12, 4)
  disponibilidad       String?         @db.VarChar(100)
  situacion            String?         @db.VarChar(100)
  fecExp               DateTime?       @map("fec_exp") @db.Date
  requerimiento        Decimal?        @db.Decimal(12, 4)
  ajuste               Decimal?        @db.Decimal(12, 4)
  archivoNombre        String?         @map("archivo_nombre") @db.VarChar(255)
  usuarioId            String?         @map("usuario_id") @db.Uuid
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  establecimiento      Establecimiento @relation(fields: [establecimientoId], references: [id], onDelete: Cascade)
  vacuna               Vacuna          @relation(fields: [vacunaId], references: [id], onDelete: Restrict)
  usuario              Usuario?        @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@unique([establecimientoId, vacunaId, anio], name: "uk_ici_demid_establecimiento_vacuna_anio")
  @@index([anio], name: "idx_ici_demid_anio")
  @@index([establecimientoId], name: "idx_ici_demid_establecimiento")
  @@index([vacunaId], name: "idx_ici_demid_vacuna")
  @@map("ici_demid_registros")
}

model PlanificacionAnual {
  id                   String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  establecimientoId    String              @map("establecimiento_id") @db.Uuid
  vacunaId             String              @map("vacuna_id") @db.Uuid
  anio                 Int
  metaAnual            Int                 @map("meta_anual")
  distribucionMensual  Int[]               @map("distribucion_mensual")
  estado               EstadoPlanificacion @default(borrador)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  establecimiento      Establecimiento     @relation(fields: [establecimientoId], references: [id])
  vacuna               Vacuna              @relation(fields: [vacunaId], references: [id])

  @@unique([establecimientoId, vacunaId, anio], name: "uk_planificacion_establecimiento_vacuna_anio")
  @@map("planificacion_anual")
}

model ProgramacionAnualCenares {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vacunaId      String?       @map("vacuna_id") @db.Uuid
  jeringaId     String?       @map("jeringa_id") @db.Uuid
  anio          Int
  programadoQ1  Int           @default(0) @map("programado_q1")
  programadoQ2  Int           @default(0) @map("programado_q2")
  programadoQ3  Int           @default(0) @map("programado_q3")
  programadoQ4  Int           @default(0) @map("programado_q4")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  vacuna        Vacuna?       @relation("ProgramacionCenaresVacuna", fields: [vacunaId], references: [id])
  jeringa       Jeringa?      @relation("ProgramacionCenaresJeringa", fields: [jeringaId], references: [id])

  // Constraints: debe tener vacuna O jeringa, pero no ambos
  @@unique([vacunaId, anio], name: "uk_programacion_cenares_vacuna_anio")
  @@unique([jeringaId, anio], name: "uk_programacion_cenares_jeringa_anio")
  @@index([anio], name: "idx_programacion_cenares_anio")
  @@index([vacunaId], name: "idx_programacion_cenares_vacuna")
  @@index([jeringaId], name: "idx_programacion_cenares_jeringa")
  @@map("programacion_anual_cenares")
}

model MovimientoVacuna {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  establecimientoId String             @map("establecimiento_id") @db.Uuid
  vacunaId          String             @map("vacuna_id") @db.Uuid
  mes               Int
  anio              Int
  saldoAnterior     Int                @default(0) @map("saldo_anterior")
  transIngreso      Int                @default(0) @map("trans_ingreso")
  salida            Int                @default(0)
  transSalida       Int                @default(0) @map("trans_salida")
  entrega           Int                @default(0)
  entregaBase       Int?               @map("entrega_base") // Valor base de planificación (null = usar entrega)
  observaciones     String?            @db.Text
  fechaMovimiento   DateTime           @default(now()) @map("fecha_movimiento") @db.Date
  usuarioId         String             @map("usuario_id") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  establecimiento   Establecimiento    @relation(fields: [establecimientoId], references: [id])
  vacuna            Vacuna             @relation(fields: [vacunaId], references: [id])
  usuario           Usuario            @relation(fields: [usuarioId], references: [id])
  entregasAdicionales EntregaAdicional[]

  @@unique([establecimientoId, vacunaId, mes, anio], name: "uk_movimiento_establecimiento_vacuna_mes_anio")
  @@map("movimientos_vacunas")
}

model EntregaAdicional {
  id                  String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  movimientoVacunaId  String           @map("movimiento_vacuna_id") @db.Uuid
  numeroEntrega       Int              @map("numero_entrega")
  cantidad            Int
  fechaEntrega        DateTime         @default(now()) @map("fecha_entrega") @db.Date
  motivo              String?          @db.Text
  usuarioId           String           @map("usuario_id") @db.Uuid
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relaciones
  movimientoVacuna    MovimientoVacuna @relation(fields: [movimientoVacunaId], references: [id])
  usuario             Usuario          @relation(fields: [usuarioId], references: [id])

  @@unique([movimientoVacunaId, numeroEntrega], name: "uk_movimiento_numero_entrega")
  @@map("entregas_adicionales")
}

model ValeEntrega {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numero                String        @unique @db.VarChar(50)
  centroAcopioId        String        @map("centro_acopio_id") @db.Uuid
  mes                   Int
  anio                  Int
  fechaGeneracion       DateTime      @default(now()) @map("fecha_generacion") @db.Timestamptz(6)
  estado                EstadoVale    @default(generado)
  tipoVale              TipoVale      @default(completo) @map("tipo_vale")
  gruposEntregasAdicionales String?   @map("grupos_entregas_adicionales") @db.Text
  totalVacunas          Int           @default(0) @map("total_vacunas")
  totalEstablecimientos Int           @default(0) @map("total_establecimientos")
  usuarioId             String        @map("usuario_id") @db.Uuid
  observaciones         String?       @db.Text
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  centroAcopio          CentroAcopio    @relation(fields: [centroAcopioId], references: [id])
  usuario               Usuario         @relation(fields: [usuarioId], references: [id])
  detalles              ValeDetalle[]

  // Permitir múltiples vales por período pero con diferentes tipos y grupos
  @@unique([centroAcopioId, mes, anio, tipoVale, gruposEntregasAdicionales], name: "uk_centro_periodo_tipo_grupos")
  @@map("vales_entrega")
}

model ValeDetalle {
  id                      String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  valeEntregaId           String          @map("vale_entrega_id") @db.Uuid
  establecimientoId       String          @map("establecimiento_id") @db.Uuid
  vacunaId                String          @map("vacuna_id") @db.Uuid
  cantidadProgramada      Int             @default(0) @map("cantidad_programada")
  cantidadAdicional       Int             @default(0) @map("cantidad_adicional")
  numeroEntregaAdicional  Int?            @map("numero_entrega_adicional")
  createdAt               DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relaciones
  valeEntrega             ValeEntrega     @relation(fields: [valeEntregaId], references: [id])
  establecimiento         Establecimiento @relation(fields: [establecimientoId], references: [id])
  vacuna                  Vacuna          @relation(fields: [vacunaId], references: [id])

  @@unique([valeEntregaId, establecimientoId, vacunaId, numeroEntregaAdicional], name: "uk_vale_establecimiento_vacuna")
  @@map("vales_detalle")
}

model Kardex {
  id                        String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tipo                      String                @db.VarChar(20)
  itemId                    String                @map("item_id") @db.Uuid
  loteId                    String                @map("lote_id") @db.Uuid
  tipoMovimiento            TipoMovimientoKardex  @map("tipo_movimiento")
  cantidad                  Int
  saldoAnterior             Int                   @default(0) @map("saldo_anterior")
  saldoActual               Int                   @map("saldo_actual")
  establecimientoOrigenId   String?               @map("establecimiento_origen_id") @db.Uuid
  establecimientoDestinoId  String?               @map("establecimiento_destino_id") @db.Uuid
  documento                 String                @db.VarChar(100)
  numeroDocumento           String                @map("numero_documento") @db.VarChar(100)
  observaciones             String?               @db.Text
  usuarioId                 String                @map("usuario_id") @db.Uuid
  fechaMovimiento           DateTime              @default(now()) @map("fecha_movimiento") @db.Timestamptz(6)
  createdAt                 DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relaciones
  establecimientoOrigen     Establecimiento?      @relation("KardexOrigen", fields: [establecimientoOrigenId], references: [id])
  establecimientoDestino    Establecimiento?      @relation("KardexDestino", fields: [establecimientoDestinoId], references: [id])
  usuario                   Usuario               @relation(fields: [usuarioId], references: [id])

  @@map("kardex")
}

model Alerta {
  id                String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tipo              TipoAlerta
  titulo            String      @db.VarChar(255)
  descripcion       String      @db.Text
  nivel             NivelAlerta
  fechaCreacion     DateTime    @default(now()) @map("fecha_creacion") @db.Timestamptz(6)
  fechaVencimiento  DateTime?   @map("fecha_vencimiento") @db.Timestamptz(6)
  leida             Boolean     @default(false)
  usuarioId         String?     @map("usuario_id") @db.Uuid
  parametros        Json?       @db.JsonB
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  usuario           Usuario?    @relation(fields: [usuarioId], references: [id])

  @@index([leida, usuarioId, fechaCreacion], name: "idx_alertas_leida_usuario_fecha")
  @@index([tipo, fechaCreacion], name: "idx_alertas_tipo_fecha")
  @@index([nivel, fechaCreacion], name: "idx_alertas_nivel_fecha")
  @@index([fechaVencimiento], name: "idx_alertas_fecha_vencimiento")
  @@map("alertas")
}

model ConfiguracionSistema {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clave       String   @unique @db.VarChar(100)
  valor       String   @db.Text
  descripcion String?  @db.Text
  tipoDato    String   @default("string") @map("tipo_dato") @db.VarChar(20)
  categoria   String   @default("general") @db.VarChar(50)
  esPublico   Boolean  @default(false) @map("es_publico")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("configuracion_sistema")
}

model StockInicialMensual {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vacunaId          String        @map("vacuna_id") @db.Uuid
  mes               Int
  anio              Int
  stockInicial      Int           @map("stock_inicial")
  fechaCaptura      DateTime      @default(now()) @map("fecha_captura") @db.Timestamptz(6)
  observaciones     String?       @db.Text
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relaciones
  vacuna            Vacuna        @relation(fields: [vacunaId], references: [id])

  // Constraints
  @@unique([vacunaId, mes, anio], name: "uk_stock_inicial_vacuna_mes_anio")
  @@index([vacunaId], name: "idx_stock_inicial_vacuna")
  @@index([mes, anio], name: "idx_stock_inicial_periodo")
  @@map("stock_inicial_mensual")
}

model ConfiguracionJeringaVacunaDefecto {
  id           String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vacunaId     String        @map("vacuna_id") @db.Uuid
  jeringaId    String        @map("jeringa_id") @db.Uuid
  multiplicador Decimal      @default(1.0) @db.Decimal(10, 4)
  prioridad    Int           @default(1)
  activo       Boolean       @default(true)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  vacuna       Vacuna        @relation(fields: [vacunaId], references: [id], onDelete: Cascade)
  jeringa      Jeringa       @relation(fields: [jeringaId], references: [id], onDelete: Cascade)

  // Constraints
  @@unique([vacunaId, jeringaId], name: "uk_vacuna_jeringa_defecto")
  @@index([vacunaId], name: "idx_config_defecto_vacuna")
  @@index([jeringaId], name: "idx_config_defecto_jeringa")
  @@index([activo], name: "idx_config_defecto_activo")
  @@index([vacunaId, prioridad], name: "idx_config_defecto_prioridad")
  @@map("configuracion_jeringa_vacuna_defecto")
}

model ConfiguracionJeringaVacunaCentro {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  centroAcopioId  String        @map("centro_acopio_id") @db.Uuid
  vacunaId        String        @map("vacuna_id") @db.Uuid
  jeringaId       String        @map("jeringa_id") @db.Uuid
  multiplicador   Decimal       @default(1.0) @db.Decimal(10, 4)
  prioridad       Int           @default(1)
  activo          Boolean       @default(true)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  centroAcopio    CentroAcopio  @relation(fields: [centroAcopioId], references: [id], onDelete: Cascade)
  vacuna          Vacuna        @relation(fields: [vacunaId], references: [id], onDelete: Cascade)
  jeringa         Jeringa       @relation(fields: [jeringaId], references: [id], onDelete: Cascade)

  // Constraints
  @@unique([centroAcopioId, vacunaId, jeringaId], name: "uk_centro_vacuna_jeringa")
  @@index([centroAcopioId], name: "idx_config_centro_centro")
  @@index([vacunaId], name: "idx_config_centro_vacuna")
  @@index([jeringaId], name: "idx_config_centro_jeringa")
  @@index([activo], name: "idx_config_centro_activo")
  @@index([centroAcopioId, vacunaId, prioridad], name: "idx_config_centro_prioridad")
  @@map("configuracion_jeringa_vacuna_centro")
}

// =====================================================
// ROLES AND PERMISSIONS SYSTEM
// =====================================================

model Role {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre      String   @unique @db.VarChar(100)
  descripcion String?  @db.VarChar(500)
  codigo      String   @unique @db.VarChar(50) // Para compatibilidad con RolUsuario enum
  estado      EstadoGeneral @default(activo)
  esDefault   Boolean  @default(false) @map("es_default") // Indica si es un rol por defecto del sistema
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  rolePermissions RolePermission[]
  usuarios        Usuario[] @relation("UsuarioRole")

  @@index([codigo], name: "idx_role_codigo")
  @@index([estado], name: "idx_role_estado")
  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre      String   @unique @db.VarChar(100)
  descripcion String?  @db.VarChar(500)
  codigo      String   @unique @db.VarChar(100) // ej: "usuarios:read", "reportes:write"
  recurso     String   @db.VarChar(50) // ej: "usuarios", "reportes", "planificacion"
  accion      String   @db.VarChar(50) // ej: "read", "write", "delete", "export"
  categoria   String   @db.VarChar(50) // Para agrupar permisos en la UI
  estado      EstadoGeneral @default(activo)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  rolePermissions RolePermission[]

  @@index([codigo], name: "idx_permission_codigo")
  @@index([recurso], name: "idx_permission_recurso")
  @@index([categoria], name: "idx_permission_categoria")
  @@index([estado], name: "idx_permission_estado")
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relaciones
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], name: "unique_role_permission")
  @@index([roleId], name: "idx_role_permission_role")
  @@index([permissionId], name: "idx_role_permission_permission")
  @@map("role_permissions")
}

// =====================================================
// PERMISOS OPERATIVOS
// =====================================================

model PermisoOperativo {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tipo               String    @db.VarChar(50)
  usuarioId          String?   @map("usuario_id") @db.Uuid
  mes                Int
  anio               Int
  habilitado         Boolean   @default(false)
  programado         Boolean   @default(false)
  fechaActivacion    DateTime? @map("fecha_activacion") @db.Timestamptz(6)
  fechaDesactivacion DateTime? @map("fecha_desactivacion") @db.Timestamptz(6)
  creadoPorId        String    @map("creado_por_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  usuario            Usuario?  @relation("PermisoOperativoUsuario", fields: [usuarioId], references: [id], onDelete: Cascade)
  creadoPor          Usuario   @relation("PermisoOperativoCreadoPor", fields: [creadoPorId], references: [id])

  @@unique([tipo, usuarioId, mes, anio], name: "uk_permiso_operativo")
  @@index([tipo, mes, anio], name: "idx_permiso_operativo_tipo_periodo")
  @@index([usuarioId], name: "idx_permiso_operativo_usuario")
  @@index([habilitado, fechaActivacion], name: "idx_permiso_operativo_programado")
  @@map("permisos_operativos")
}
