{
  "name": "sivac-backend",
  "version": "1.0.0",
  "description": "Backend API para Sistema SIVAC - Gestión de Vacunas",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node -r ./register-aliases.js dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:migrate-entrega-base": "tsx scripts/migrate-entrega-base.ts",
    "db:create-triggers": "tsx scripts/create-triggers.ts",
    "db:setup": "tsx scripts/setup-database.ts",
    "db:migrate-tipo-vale": "node scripts/apply-tipo-vale-migration.js",
    "test:multiple-vouchers": "node scripts/test-multiple-vouchers.js",
    "verify:solution": "node scripts/verify-solution.js",
    "clear-rate-limit": "node ../scripts/clear-rate-limit.js",
    "fix:lotes": "tsx scripts/run-lote-correction.ts",
    "fix:lotes-verify": "tsx scripts/run-lote-correction.ts -- --verificar-solo",
    "fix:lotes-correct": "tsx scripts/run-lote-correction.ts -- --corregir --backup",
    "fix:lotes-dt": "tsx scripts/run-lote-correction.ts -- --caso-dt",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "sivac",
    "vacunas",
    "api",
    "typescript",
    "prisma"
  ],
  "author": "DISA Apurímac II",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.51",
    "@ai-sdk/openai-compatible": "^2.0.38",
    "@prisma/client": "^5.7.1",
    "@types/bcrypt": "^5.0.2",
    "@types/multer": "^2.0.0",
    "ai": "^6.0.146",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "node-fetch": "^2.7.0",
    "pdfkit": "^0.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^4.17.21",
    "@types/express-validator": "^2.20.33",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.4",
    "@types/pdfkit": "^0.17.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.1",
    "supertest": "^7.1.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
